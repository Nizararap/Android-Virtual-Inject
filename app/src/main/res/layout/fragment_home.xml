<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/vi_bg">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="20dp"
        android:paddingTop="12dp"
        android:paddingBottom="8dp"
        android:gravity="center_vertical">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/app_name"
                android:textColor="@color/vi_text_primary"
                android:textSize="22sp"
                android:textStyle="bold"
                android:letterSpacing="-0.02" />

            <TextView
                android:id="@+id/header_subtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="1dp"
                android:text="Tap app untuk di-clone"
                android:textColor="@color/vi_text_hint"
                android:textSize="11sp" />
        </LinearLayout>

        <TextView
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="@drawable/bg_logo"
            android:gravity="center"
            android:text="VI"
            android:textColor="#FFFFFF"
            android:textSize="12sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- Tabs -->
    <com.google.android.material.tabs.TabLayout
        android:id="@+id/tab_layout"
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:layout_marginHorizontal="20dp"
        android:layout_marginBottom="10dp"
        app:tabBackground="@android:color/transparent"
        app:tabGravity="start"
        app:tabMode="scrollable"
        app:tabIndicatorColor="@color/vi_tab_indicator"
        app:tabIndicatorFullWidth="false"
        app:tabIndicatorHeight="2dp"
        app:tabSelectedTextColor="@color/vi_accent_light"
        app:tabTextColor="@color/vi_text_hint"
        app:tabTextAppearance="@style/TabTextAppearance"
        app:tabRippleColor="@color/vi_accent_dim" />

    <!-- Search bar (visible only on All tab) -->
    <LinearLayout
        android:id="@+id/search_bar"
        android:layout_width="match_parent"
        android:layout_height="38dp"
        android:layout_marginHorizontal="20dp"
        android:layout_marginBottom="10dp"
        android:background="@drawable/bg_search"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="12dp">

        <TextView
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:text="🔍"
            android:textSize="13sp"
            android:alpha="0.4" />

        <EditText
            android:id="@+id/search_input"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="@null"
            android:hint="@string/search_hint"
            android:textColorHint="@color/vi_text_hint"
            android:imeOptions="actionSearch"
            android:inputType="text"
            android:paddingHorizontal="8dp"
            android:singleLine="true"
            android:textColor="@color/vi_text_primary"
            android:textSize="12.5sp" />

        <TextView
            android:id="@+id/search_clear"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:clickable="true"
            android:focusable="true"
            android:padding="4dp"
            android:text="✕"
            android:textColor="@color/vi_text_hint"
            android:textSize="11sp"
            android:visibility="gone" />
    </LinearLayout>

    <!-- Content: ALL apps grid / CLONED list -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <!-- All apps grid -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_all_apps"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:paddingHorizontal="8dp"
            android:paddingBottom="16dp" />

        <!-- Cloned apps list -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_cloned_apps"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:paddingTop="4dp"
            android:paddingBottom="16dp"
            android:visibility="gone" />

        <!-- Empty state for cloned tab -->
        <LinearLayout
            android:id="@+id/empty_cloned"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:orientation="vertical"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📦"
                android:textSize="38sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="@string/empty_cloned"
                android:textColor="@color/vi_text_hint"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/btn_go_add"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:background="@drawable/bg_add_btn"
                android:clickable="true"
                android:focusable="true"
                android:paddingHorizontal="20dp"
                android:paddingVertical="8dp"
                android:text="@string/add_app"
                android:textColor="@color/vi_accent_light"
                android:textSize="12sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Empty search result -->
        <TextView
            android:id="@+id/empty_search"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:text="@string/no_result"
            android:textColor="@color/vi_text_hint"
            android:textSize="13sp"
            android:visibility="gone" />
    </FrameLayout>
</LinearLayout>
